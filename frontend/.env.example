# The frontend calls its own origin at /api/* and Next proxies to the backend
# (see next.config.ts). You normally do NOT need to set a backend URL here.
#
# Proxy target — server-side var, NOT NEXT_PUBLIC. Defaults to http://localhost:8000.
# docker-compose passes http://backend:8000 as a build arg.
#   API_PROXY_TARGET=http://localhost:8000
#
# Only set NEXT_PUBLIC_API_BASE_URL to make the browser call an absolute backend
# URL directly (bypasses the /api proxy, requires CORS). It is baked into the
# client bundle at build time, so use an address the browser can actually reach —
# under docker-compose the backend is exposed on host :8100, not :8000.
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8100
