NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=devpassword

# OpenAI-compatible LLM for developer-profile parsing. Leave blank to use the
# deterministic rule parser. All three of BASE_URL/API_KEY/MODEL are required to
# enable the LLM path.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT=30
