NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=devpassword

# OpenAI-compatible LLM for developer-profile parsing. Leave blank to use the
# deterministic rule parser. All three of BASE_URL/API_KEY/MODEL are required to
# enable the LLM path.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT=30
# 可选：合并进请求体顶层的 provider 专属参数（JSON 对象）。核心字段
# (model/messages/tools/tool_choice) 不会被覆盖。典型用途：思考/推理模型默认
# 拒绝强制 tool_choice（报 "thinking mode does not support this tool_choice"），
# 用它关掉思考模式即可。Qwen3(DashScope 兼容模式) 示例：
# LLM_EXTRA_BODY={"enable_thinking": false}
LLM_EXTRA_BODY=
